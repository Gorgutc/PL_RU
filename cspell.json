{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "files": ["src/**/*.{ts,tsx,scss}", "tests/**/*.{ts,tsx}", "DO_NOT_PUSH.md"],
  "ignorePaths": [
    "codex_*.md",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    "docs/**",
    "pnpm-lock.yaml",
    "package.json",
    "knip.json",
    "lighthouserc.cjs",
    "scripts/**",
    "verify-frozen.ts",
    "tsconfig.tsbuildinfo",
    ".next/**",
    "out/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**",
    ".lighthouseci/**",
    "jscpd-report/**",
    "reports/**",
    "scratch/**",
    "public/left-rail-icons/**",
    "public/top-control-icons/**",
    "tests/visual-qa/latest.json",
    ".codex-refs-baseline/**",
    "Blueprints_lib/**",
    "Osiris_ref/**",
    "plugins/pl-ru-codex/skills/**"
  ],
  "ignoreRegExpList": ["[\\u0400-\\u04FF]+"],
  "words": [
    "artboard",
    "artboards",
    "blueprintjs",
    "labelledby",
    "lighthouseci",
    "lighthouserc",
    "maplibre",
    "maplibregl",
    "networkidle",
    "nums",
    "OpenStreetMap",
    "pampushka",
    "Prai",
    "PraiOS",
    "sfmono",
    "textareas",
    "ultrawide",
    "viewports",
    "zerolinetool"
  ]
}
