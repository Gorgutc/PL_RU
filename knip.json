{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx,mjs}",
    "scripts/**/*.{js,mjs}",
    "verify-frozen.ts",
    "next.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "eslint.config.mjs"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx,mjs}",
    "scripts/**/*.{js,mjs}",
    "*.config.{ts,js,mjs,cjs}",
    "verify-frozen.ts"
  ],
  "ignoreDependencies": ["@eslint/eslintrc", "@eslint/js", "@lhci/cli", "framer-motion"]
}
