{
  "name": "ts-frontend-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "stylelint:fix": "stylelint \"src/**/*.scss\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:js": "pnpm lint",
    "check:css": "pnpm stylelint",
    "check:html": "node scripts/run-htmlhint.mjs",
    "check:markdown": "markdownlint-cli2",
    "check:spelling": "cspell . --no-progress",
    "check:deps": "depcruise --config dependency-cruiser.config.cjs src scripts tests verify-frozen.ts next.config.ts playwright.config.ts playwright.quality.config.ts vitest.config.ts",
    "check:dead": "knip --exclude unlisted --no-config-hints",
    "check:duplicates": "jscpd --config .jscpd.json --noTips .",
    "check:visual": "node scripts/check-visual-evidence.mjs",
    "design:crop": "node scripts/visual/crop-designer-refs.mjs",
    "design:check": "node scripts/visual/compare-designer-crops.mjs",
    "check:audit": "pnpm audit --prod --audit-level high",
    "check:a11y": "playwright test --config=playwright.quality.config.ts && node scripts/run-pa11y.mjs",
    "check:lighthouse": "pnpm build && node scripts/run-lhci.mjs",
    "test:browser": "pnpm test:e2e",
    "check:format": "pnpm format:check",
    "verify": "tsx verify-frozen.ts",
    "verify:static": "tsx verify-frozen.ts --static",
    "ship": "pnpm codex:ship",
    "refs:sync": "node scripts/sync-refs.mjs",
    "refs:verify": "node scripts/verify-reference.js",
    "hooks:install": "lefthook install",
    "codex:verify-plugin": "node scripts/verify-codex-plugin.mjs",
    "quality:fast": "pnpm check:format && pnpm check:js && pnpm check:css && pnpm typecheck && pnpm test && pnpm verify:static && pnpm codex:verify-plugin",
    "quality:deep": "pnpm quality:fast && pnpm check:html && pnpm check:markdown && pnpm check:spelling && pnpm check:deps && pnpm check:dead && pnpm check:duplicates && pnpm check:visual && pnpm test:browser && pnpm check:a11y && pnpm verify",
    "quality:all": "pnpm refs:sync && pnpm quality:deep && pnpm check:audit && pnpm check:lighthouse && pnpm refs:verify",
    "codex:ship": "pnpm quality:all"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.0.0",
    "@blueprintjs/icons": "^6.0.0",
    "framer-motion": "^12.0.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.56.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cspell": "^10.0.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^15.0.0",
    "htmlhint": "^1.9.2",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "markdownlint-cli2": "^0.22.1",
    "pa11y": "^9.1.1",
    "playwright": "1.56.1",
    "prettier": "^3.4.0",
    "sass": "^1.83.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-order": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "@types/react": "19",
        "@types/react-dom": "19"
      }
    }
  }
}
