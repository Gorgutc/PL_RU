{
  "name": "ts-frontend-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "stylelint:fix": "stylelint \"src/**/*.scss\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:js": "corepack pnpm run lint",
    "check:css": "corepack pnpm run stylelint",
    "check:html": "node scripts/run-htmlhint.mjs",
    "check:markdown": "markdownlint-cli2",
    "check:spelling": "cspell . --no-progress",
    "check:deps": "depcruise --config dependency-cruiser.config.cjs src scripts tests verify-frozen.ts next.config.ts playwright.config.ts playwright.quality.config.ts vitest.config.ts",
    "check:dead": "knip --exclude unlisted --no-config-hints",
    "check:duplicates": "jscpd --config .jscpd.json --noTips .",
    "check:visual": "node scripts/check-visual-evidence.mjs",
    "check:audit": "corepack pnpm audit --prod --audit-level low",
    "check:a11y": "playwright test --config=playwright.quality.config.ts && node scripts/run-pa11y.mjs",
    "check:lighthouse": "corepack pnpm run build && node scripts/run-lhci.mjs",
    "test:browser": "corepack pnpm run test:e2e",
    "check:format": "corepack pnpm run format:check",
    "verify": "tsx verify-frozen.ts",
    "verify:static": "tsx verify-frozen.ts --static",
    "ship": "corepack pnpm run codex:ship",
    "refs:sync": "node scripts/sync-refs.mjs",
    "refs:verify": "node scripts/verify-reference.js",
    "hooks:install": "lefthook install",
    "codex:verify-plugin": "node scripts/verify-codex-plugin.mjs",
    "quality:fast": "corepack pnpm run check:format && corepack pnpm run check:js && corepack pnpm run check:css && corepack pnpm run typecheck && corepack pnpm run test && corepack pnpm run verify:static && corepack pnpm run codex:verify-plugin",
    "quality:deep": "corepack pnpm run quality:fast && corepack pnpm run check:html && corepack pnpm run check:markdown && corepack pnpm run check:spelling && corepack pnpm run check:deps && corepack pnpm run check:dead && corepack pnpm run check:duplicates && corepack pnpm run check:audit && corepack pnpm run check:visual && corepack pnpm run test:browser && corepack pnpm run check:a11y && corepack pnpm run verify",
    "quality:all": "corepack pnpm run refs:sync && corepack pnpm run quality:deep && corepack pnpm run check:lighthouse && corepack pnpm run refs:verify",
    "codex:ship": "corepack pnpm run quality:all"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.0.0",
    "@blueprintjs/icons": "^6.0.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.56.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cspell": "^10.0.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^15.0.0",
    "htmlhint": "^1.9.2",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "markdownlint-cli2": "^0.22.1",
    "pa11y": "^9.1.1",
    "playwright": "1.56.1",
    "prettier": "^3.4.0",
    "sass": "^1.83.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-order": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "postcss": "8.5.15"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "@types/react": "19",
        "@types/react-dom": "19"
      }
    }
  }
}
